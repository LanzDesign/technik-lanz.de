# EmailJS Konfiguration
# Kopiere diese Datei zu .env und füge deine echten Werte ein
# Erstelle deinen Account auf https://www.emailjs.com/

REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxxxx
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxxxx

# Google Analytics (optional)
# REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
